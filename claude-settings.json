{
  "theme": "dark",
  "hasCompletedOnboarding": true,
  "apiKeyHelper": "/usr/local/bin/claude-api-key",
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "// --- File reads ---",
      "Glob",
      "Grep",
      "Read",

      "// --- Network ---",
      "WebFetch",

      "// --- Shell utils ---",
      "Bash(awk *)",
      "Bash(cat *)",
      "Bash(curl *)",
      "Bash(echo *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(ps *)",
      "Bash(sed *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(which *)",

      "// --- npm ---",
      "Bash(npm audit*)",
      "Bash(npm ci*)",
      "Bash(npm i*)",
      "Bash(npm install*)",
      "Bash(npm ls*)",
      "Bash(npm run *)",
      "Bash(npm start*)",
      "Bash(npm test*)",

      "// --- yarn ---",
      "Bash(yarn)",
      "Bash(yarn build*)",
      "Bash(yarn i*)",
      "Bash(yarn install*)",
      "Bash(yarn lint*)",
      "Bash(yarn prettier*)",
      "Bash(yarn run *)",
      "Bash(yarn teleport*)",
      "Bash(yarn test*)",

      "// --- Kubernetes (read-only) ---",
      "Bash(kubectl auth *)",
      "Bash(kubectl describe *)",
      "Bash(kubectl get *)",
      "Bash(kubectl logs *)",
      "Bash(kubectl port-forward *)",
      "Bash(kubectl rollout status *)",
      "Bash(kns *)",
      "Bash(kubectx *)",
      "Bash(kubens *)",

      "// --- GitHub CLI (read-only) ---",
      "Bash(gh api *)",
      "Bash(gh issue list*)",
      "Bash(gh issue view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(gh pr checks*)",
      "Bash(gh pr diff*)",
      "Bash(gh release list*)",
      "Bash(gh release view*)",
      "Bash(gh repo view*)",
      "Bash(gh run list*)",
      "Bash(gh run view*)",
      "Bash(gh search *)",
      "Bash(gh status*)",
      "Bash(gh workflow list*)",
      "Bash(gh workflow view*)",
      "Bash(gh pr edit*)",
      "Bash(gh run rerun*)",
      "Bash(gh workflow run*)"
    ],
    "deny": [
      "// --- GitHub CLI (write) ---",
      "Bash(gh issue close*)",
      "Bash(gh issue create*)",
      "Bash(gh issue edit*)",
      "Bash(gh pr close*)",
      "Bash(gh pr create*)",
      "Bash(gh pr merge*)",
      "Bash(gh pr review*)",
      "Bash(gh release create*)",
      "Bash(gh release delete*)",
      "Bash(gh repo create*)",
      "Bash(gh repo delete*)",
      "Bash(gh workflow enable*)",
      "Bash(gh workflow disable*)",

      "// --- Destructive git ---",
      "Bash(git clean -f*)",
      "Bash(git push*)",
      "Bash(git reset --hard*)",

      "// --- Destructive k8s ---",
      "Bash(kubectl delete *)",

      "// --- Destructive shell ---",
      "Bash(rm -rf *)"
    ]
  }
}
